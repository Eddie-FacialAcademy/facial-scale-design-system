{
  "$meta": {
    "name": "Facial Scale Design System",
    "version": "1.0.0",
    "author": "Edegar Junior",
    "source": "Identidade visual própria da Facial Scale (ecossistema Facial Academy)",
    "language": "pt-BR",
    "themes": ["dark", "light"],
    "defaultTheme": "dark",
    "direction": "Accent/CTA/links = rosé + nude (predominantes); roxo só pontual (logo, info, destaques).",
    "note": "Cores derivadas das 7 institucionais. Nada deve sair desta paleta. Aplique tokens, nunca hex solto nos componentes."
  },

  "breakpoints": { "desktop": 1200, "tablet": 810, "phone": 390 },

  "color": {
    "brand": {
      "roxo": "#3E1968", "lilas": "#A98AD0", "amarelo": "#CDA29B",
      "vermelho": "#E8D5CE", "amarelado": "#DDB9AE", "branco": "#FFFFFF", "preto": "#000000"
    },
    "dark": {
      "bg": "#14100E", "bg2": "#1D1714", "card": "#251C18", "card2": "#30241E",
      "line": "rgba(205,162,155,.16)",
      "roxo": "#5C342D", "roxo2": "#8A554B", "roxoBright": "#743F36",
      "lilas": "#D6A99F", "lilasSoft": "#E8D5CE",
      "txt": "#FBF6F4", "mut": "#C8B6AF", "legalMut": "#A28C84",
      "gold": "#CDA29B", "goldDeep": "#B98C84", "goldInk": "#CDA29B", "goldLine": "rgba(205,162,155,.42)",
      "rose": "#E8D5CE", "roseInk": "#E8D5CE", "roseLine": "rgba(232,213,206,.42)",
      "peach": "#DDB9AE", "logo": "#FFFFFF",
      "success": "#45C08A", "warning": "#E8B53D", "danger": "#FF7D93", "info": "#A98AD0",
      "successBg": "rgba(69,192,138,.14)", "warningBg": "rgba(232,181,61,.14)", "dangerBg": "rgba(255,125,147,.14)", "infoBg": "rgba(169,138,208,.14)", "rowSel": "rgba(205,162,155,.16)",
      "shadow": "rgba(138,90,80,.40)", "shadowStrong": "rgba(138,90,80,.50)"
    },
    "light": {
      "bg": "#FBF6F4", "bg2": "#F6ECE8", "card": "#FDF8F6", "card2": "#F4E5DF",
      "line": "rgba(138,90,80,.16)",
      "roxo": "#5C342D", "roxo2": "#8A554B", "roxoBright": "#743F36",
      "lilas": "#8A554B", "lilasSoft": "#6E4640",
      "txt": "#2B2730", "mut": "#6F5C55", "legalMut": "#6F5C55",
      "gold": "#CDA29B", "goldDeep": "#B98C84", "goldInk": "#8E5A50", "goldLine": "rgba(142,90,80,.55)",
      "rose": "#E8D5CE", "roseInk": "#8A6258", "roseLine": "rgba(138,98,88,.50)",
      "peach": "#DDB9AE", "logo": "#3E1968",
      "success": "#147A45", "warning": "#8A5A00", "danger": "#BE2C45", "info": "#5B3A86",
      "successBg": "rgba(31,138,91,.10)", "warningBg": "rgba(138,90,0,.10)", "dangerBg": "rgba(199,47,73,.10)", "infoBg": "rgba(91,58,134,.10)", "rowSel": "rgba(138,90,80,.10)",
      "shadow": "rgba(138,90,80,.18)", "shadowStrong": "rgba(138,90,80,.26)"
    }
  },

  "elevation": {
    "roles": { "raised": "1", "overlay": "3", "modal": "4" },
    "dark": {
      "1": "0 1px 2px rgba(0,0,0,.34), 0 2px 6px rgba(0,0,0,.30)", "2": "0 2px 4px rgba(0,0,0,.34), 0 8px 18px rgba(0,0,0,.40)",
      "3": "0 4px 12px rgba(0,0,0,.45), 0 16px 36px rgba(0,0,0,.55)", "4": "0 10px 24px rgba(0,0,0,.5), 0 28px 64px rgba(0,0,0,.62)"
    },
    "light": {
      "1": "0 1px 2px rgba(138,90,80,.10), 0 2px 6px rgba(138,90,80,.08)", "2": "0 2px 4px rgba(138,90,80,.10), 0 8px 16px rgba(138,90,80,.12)",
      "3": "0 4px 10px rgba(138,90,80,.12), 0 16px 32px rgba(138,90,80,.16)", "4": "0 8px 18px rgba(138,90,80,.14), 0 28px 56px rgba(138,90,80,.22)"
    }
  },

  "radius": { "sm": "8px", "md": "14px", "lg": "18px", "pill": "30px" },
  "foundations": {
    "opacity": { "disabled": 0.45, "muted": 0.66, "hover": 0.08, "overlay": 0.58 },
    "borderWidth": { "hair": "1px", "1": "1px", "2": "2px" },
    "blur": { "sm": "6px", "md": "12px", "lg": "20px" },
    "breakpoint": { "phone": "390px", "tablet": "810px", "desktop": "1200px" },
    "size": { "iconSm": "16px", "icon": "20px", "iconLg": "24px", "controlH": "44px", "touchMin": "44px", "rowH": "46px", "rowHCompact": "38px", "sideW": "248px", "calCell": "38px" },
    "aspectRatio": { "square": "1/1", "photo": "4/3", "wide": "16/9" }
  },
  "space":  { "1": "4px", "2": "8px", "3": "12px", "4": "16px", "6": "24px", "8": "32px", "12": "48px" },
  "zIndex": { "base": 0, "raised": 10, "sticky": 40, "overlay": 100, "toast": 1000 },
  "motion": { "fast": "0.15s", "base": "0.2s", "slow": "0.4s", "ease": "cubic-bezier(.2,.8,.2,1)" },
  "focus":  "0 0 0 3px rgba(205,162,155,.55)",

  "typography": {
    "fontFamily": "'Silka', 'Poppins', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
    "weights": [300, 400, 500, 600, 700],
    "note": "size = [desktop, tablet, phone] (px). No CSS use clamp() entre o phone e o desktop. Body mínimo 16px no mobile (evita zoom no iOS).",
    "styles": {
      "Display/H1":  { "size": [60, 44, 34], "weight": 500, "lineHeight": 1.03, "letterSpacing": "-0.025em" },
      "Heading/H2":  { "size": [38, 32, 26], "weight": 500, "lineHeight": 1.12, "letterSpacing": "-0.02em" },
      "Sub/H3":      { "size": [24, 22, 20], "weight": 500, "lineHeight": 1.2 },
      "Sub/H4":      { "size": [20, 19, 18], "weight": 500, "lineHeight": 1.25, "letterSpacing": "-0.01em" },
      "Sub/H5":      { "size": [17, 16, 16], "weight": 500, "lineHeight": 1.3 },
      "Sub/H6":      { "size": [15, 14, 14], "weight": 500, "lineHeight": 1.35 },
      "Eyebrow":     { "size": [12, 12, 11], "weight": 600, "lineHeight": 1.2, "letterSpacing": "0.18em", "uppercase": true, "color": "lilas" },
      "Lead":        { "size": [18, 17, 16], "weight": 300, "lineHeight": 1.5, "color": "mut" },
      "Body":        { "size": [16, 16, 16], "weight": 300, "lineHeight": 1.65 },
      "BodySmall":   { "size": [14, 13, 13], "weight": 300, "lineHeight": 1.6, "color": "mut" },
      "Numeral":     { "size": [44, 38, 32], "weight": 700, "lineHeight": 1, "tabularNums": true },
      "Legal":       { "size": [12, 11, 11], "weight": 300, "lineHeight": 1.5, "color": "legalMut" }
    }
  },

  "components": {
    "button": {
      "radius": "pill", "minHeight": "44px",
      "variants": ["fill", "solid", "outline", "ghost", "gold", "gold-o"],
      "sizes": { "sm": "10px 18px / 13px", "md": "14px 26px / 15px", "lg": "17px 32px / 16px" },
      "states": ["hover", "active", "focus-visible", "disabled"],
      "icon": "Phosphor Thin, currentColor, 18px (15 sm / 19 lg)"
    },
    "statusColors": ["success", "warning", "danger", "info"]
  },

  "icons": { "library": "Phosphor", "weight": "Thin", "stroke": "1pt (stroke-width 1 na grade 24)", "color": "currentColor" },

  "gradients": {
    "rule": "Direção rosé/nude; roxo só pontual. NÃO usar conic, blob ou halo. Preferir meshes (radiais multiponto) e lineares.",
    "examples": {
      "primary": "linear-gradient(120deg,#8A554B,#5C342D)",
      "spectral": "linear-gradient(110deg,#5C342D,#8A554B 28%,#D6A99F 54%,#E8D5CE 80%,#DDB9AE)",
      "mesh": "radial-gradient(at 18% 22%,rgba(205,162,155,.55) 0,transparent 45%),radial-gradient(at 78% 18%,rgba(232,213,206,.30) 0,transparent 42%),radial-gradient(at 68% 78%,rgba(138,90,80,.70) 0,transparent 50%),radial-gradient(at 30% 92%,rgba(221,185,174,.22) 0,transparent 46%),#14100E"
    }
  },

  "accessibility": {
    "contrast": "WCAG AA — texto normal ≥4.5:1, texto grande/UI ≥3:1. No light, rosé/nude como TEXTO usam -ink.",
    "focus": "outline:2px solid var(--lilas) + box-shadow var(--focus); guard @media (forced-colors: active).",
    "reducedMotion": "Respeitar prefers-reduced-motion.",
    "touchTarget": "≥44px.",
    "colorNotAlone": "Estados semânticos sempre com ícone + texto, nunca só cor."
  }
}
